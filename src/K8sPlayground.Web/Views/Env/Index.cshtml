@model List<(string Key, string Value, bool Sensitive)>
@{ ViewData["Title"] = "Environment"; }

<h3>Environment Değişkenleri</h3>
<p class="text-muted">
    Bu listede ConfigMap (<code>envFrom</code>), Secret (<code>envFrom</code>) ve Downward API ile
    enjekte edilen tüm değerler vardır. <strong>Aynı isimli env'i</strong> hem ConfigMap hem
    Pod manifest'inde tanımlayarak ezme önceliğini test edebilirsiniz.
</p>

<form class="row g-2 mb-3">
    <div class="col-auto">
        <input class="form-control" name="filter" placeholder="Arama (ör: POD, APP, DB)" value="@ViewBag.Filter" />
    </div>
    <div class="col-auto form-check pt-2">
        <input class="form-check-input" type="checkbox" name="showSecrets" value="true" id="ss"
               @(ViewBag.ShowSecrets ? "checked" : "") />
        <label class="form-check-label" for="ss">Hassas değerleri göster</label>
    </div>
    <div class="col-auto">
        <button class="btn btn-primary">Filtrele</button>
        <a class="btn btn-outline-secondary" asp-action="Index">Temizle</a>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-sm mb-0">
            <thead class="table-light"><tr><th>Anahtar</th><th>Değer</th></tr></thead>
            <tbody>
            @foreach (var (key, value, sensitive) in Model)
            {
                <tr>
                    <td>
                        <code>@key</code>
                        @if (sensitive) { <span class="badge bg-warning text-dark ms-1">hassas</span> }
                    </td>
                    <td><code class="small">@value</code></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3 small text-muted">
    Toplam: @Model.Count değişken.
    Tek bir env'i JSON olarak almak için:
    <code>GET /Env/Single?name=POD_NAME</code>
</div>
