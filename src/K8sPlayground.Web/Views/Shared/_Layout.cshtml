<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - K8s Playground</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="bg-light">
<nav class="navbar navbar-expand-lg navbar-dark" style="background:#0b3d91;">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
            ⎈ Kubernetes Playground
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="nav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item"><a class="nav-link" asp-controller="Info"    asp-action="Index">Pod Info</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Env"     asp-action="Index">Env</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Config"  asp-action="Index">Config / Secret</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Health"  asp-action="Index">Health</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Stress"  asp-action="Index">Stress</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Storage" asp-action="Index">Storage</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Network" asp-action="Index">Network</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Logs"    asp-action="Index">Logs</a></li>
                <li class="nav-item"><a class="nav-link" asp-controller="Chaos"   asp-action="Index">Chaos</a></li>
            </ul>
            <span class="navbar-text text-white-50 small">
                Pod: <code class="text-warning">@(Environment.GetEnvironmentVariable("POD_NAME") ?? Environment.MachineName)</code>
                | v@(Environment.GetEnvironmentVariable("APP_VERSION") ?? "dev")
            </span>
        </div>
    </div>
</nav>

<main class="container py-4">
    @if (TempData["msg"] is string m)
    {
        <div class="alert alert-info">@m</div>
    }
    @RenderBody()
</main>

<footer class="container text-center text-muted small py-4">
    K8s Playground — eğitim amaçlı, üretimde kullanmayın.
</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
